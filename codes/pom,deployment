pom.xml
<project xmlns="http://maven.apache.org/POM/4.0.0">
 <modelVersion>4.0.0</modelVersion>
 <groupId>com.demo</groupId>
 <artifactId>notification-app</artifactId>
 <version>1.0</version>

 <build>
  <plugins>
    <plugin>
      <artifactId>maven-compiler-plugin</artifactId>
      <version>3.10.1</version>
      <configuration>
        <source>17</source>
        <target>17</target>
      </configuration>
    </plugin>

    <plugin>
      <artifactId>maven-jar-plugin</artifactId>
      <version>3.3.0</version>
      <configuration>
        <archive>
          <manifest>
            <mainClass>App</mainClass>
          </manifest>
        </archive>
      </configuration>
    </plugin>
  </plugins>
 </build>
</project>
	
🐳 Dockerfile
FROM eclipse-temurin:17-jdk
WORKDIR /app
COPY target/notification-app-1.0.jar app.jar
CMD ["java", "-jar", "app.jar"]
	
☸️ deployment.yaml (V1)
apiVersion: apps/v1
kind: Deployment
metadata:
  name: notif-v1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: notif-v1
  template:
    metadata:
      labels:
        app: notif-v1
    spec:
      containers:
      - name: notif
        image: YOUR_USERNAME/notification-app:v1
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: notif-service-v1
spec:
  type: NodePort
  selector:
    app: notif-v1
  ports:
    - port: 80
      targetPort: 8080
      nodePort: 30001
	
